# Copy to .env and fill in as needed. All optional — defaults run offline.

# ---- Backend selection ----
# embeddings: tfidf (default, offline) | sentence-transformers | openai
EMBEDDING_BACKEND=tfidf
# summaries: template (default, offline) | anthropic | openai
SUMMARIZER_BACKEND=template
# delivery: console (default) | whatsapp
DELIVERY_BACKEND=console

# ---- Default interests (cold-start prior) ----
# Semicolon-separated topic phrases. Seeds the preference centroid before any
# feedback, so the first digest already leans your way. Feedback overrides it
# over time. Leave blank for a pure trend-strength cold start.
# DEFAULT_INTERESTS=AI agents; LLM applications; context engineering; AI code review

# ---- API keys (only needed for the non-default backends above) ----
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- WhatsApp delivery via Twilio (DELIVERY_BACKEND=whatsapp) ----
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_WHATSAPP_FROM=+14155238886
# MY_WHATSAPP_NUMBER=+91...
